# Frontend build environment (Vite)
# Copy to .env.development or .env.production and set as needed.

# Base path when app is served under a subpath (e.g. internal platform)
# Default: / (root). Set to /apps/trade-show when building for platform.
# VITE_APP_BASE_PATH=/apps/trade-show

# API base URL (optional). When not set, uses VITE_APP_BASE_PATH + /api or /api.
# VITE_API_URL=
# VITE_API_BASE_URL=/api
