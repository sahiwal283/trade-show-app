# OCR Microservice Configuration

# Environment
ENVIRONMENT=development

# OCR Provider Configuration
PRIMARY_OCR_PROVIDER=tesseract
FALLBACK_OCR_PROVIDER=
OCR_CONFIDENCE_THRESHOLD=0.6

# Python Path (use python3 or full path)
PYTHON_PATH=python3

# File Upload Settings
MAX_FILE_SIZE=10485760
UPLOAD_DIR=/tmp/ocr_uploads

# LLM Integration (Optional)
ENABLE_LLM_INFERENCE=false
LLM_PROVIDER=

# Logging
LOG_LEVEL=INFO
LOG_OCR_RESULTS=true

# CORS
CORS_ORIGINS=*

# Cache (Optional)
ENABLE_CACHE=false
CACHE_TTL=3600

# Model Retraining
RETRAINING_INTERVAL_HOURS=24
